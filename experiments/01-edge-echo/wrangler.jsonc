{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "01-edge-echo",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-01",
  "upload_source_maps": true,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1,
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1,
    },
  },
}
